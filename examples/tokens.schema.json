{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "VelinStyle tokens",
  "type": "object",
  "properties": {
    "tokens": {
      "type": "object",
      "additionalProperties": { "type": "string" }
    },
    "themes": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "additionalProperties": { "type": "string" }
      },
      "propertyNames": { "pattern": "^[a-z0-9-]+$" }
    },
    "fonts": {
      "type": "object",
      "additionalProperties": { "type": "string" }
    },
    "motion": {
      "type": "object",
      "additionalProperties": { "type": "string" }
    },
    "zIndex": {
      "type": "object",
      "additionalProperties": { "type": "string" }
    },
    "displayP3": {
      "type": "object",
      "additionalProperties": { "type": "string" }
    }
  }
}
